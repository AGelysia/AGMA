{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/connector-error.schema.json",
  "title": "AGMA Standalone Recoverable Error",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "message", "retryable"],
  "properties": {
    "code": {
      "enum": [
        "MODEL_TIMEOUT",
        "MODEL_UNAVAILABLE",
        "MODEL_AUTHENTICATION_FAILED",
        "MODEL_RESPONSE_INVALID",
        "REQUEST_CANCELLED",
        "REQUEST_LIMITED",
        "BUDGET_EXCEEDED",
        "SESSION_NOT_FOUND",
        "CONVERSATION_STORAGE_DISABLED",
        "TOOL_REJECTED",
        "TOOL_ROUND_LIMIT",
        "RUNTIME_INTERNAL_ERROR"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "retryable": { "type": "boolean" }
  }
}

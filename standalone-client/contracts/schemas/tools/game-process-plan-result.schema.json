{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/tools/game-process-plan-result.schema.json",
  "title": "AGMA Client Deterministic Process Plan Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generationId",
    "status",
    "target",
    "routes",
    "unresolved",
    "cycles",
    "exploredNodes",
    "inventoryApplied",
    "warnings"
  ],
  "properties": {
    "generationId": {
      "$ref": "client-tool-common.schema.json#/$defs/generationId"
    },
    "status": {
      "enum": ["complete", "partial", "unresolved", "cycle", "stale_generation"]
    },
    "target": {
      "$ref": "client-tool-common.schema.json#/$defs/resourceAmount"
    },
    "routes": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "complete",
          "rankingReasons",
          "steps",
          "materials",
          "inventoryUsed",
          "unresolved",
          "workstations",
          "issues"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1, "maximum": 3 },
          "complete": { "type": "boolean" },
          "rankingReasons": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {
              "enum": [
                "complete_route",
                "partial_route",
                "fewer_unresolved_resources",
                "fewer_process_steps",
                "stable_process_identity_tiebreak"
              ]
            }
          },
          "steps": {
            "type": "array",
            "maxItems": 128,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "index",
                "processId",
                "batches",
                "inputs",
                "outputs"
              ],
              "properties": {
                "index": { "type": "integer", "minimum": 0, "maximum": 127 },
                "processId": {
                  "$ref": "../resource-ref.schema.json#/$defs/namespacedId"
                },
                "batches": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 1000000000
                },
                "inputs": {
                  "type": "array",
                  "maxItems": 64,
                  "items": {
                    "$ref": "client-tool-common.schema.json#/$defs/resourceAmount"
                  }
                },
                "outputs": {
                  "type": "array",
                  "maxItems": 64,
                  "items": {
                    "$ref": "client-tool-common.schema.json#/$defs/resourceAmount"
                  }
                }
              }
            }
          },
          "materials": {
            "type": "array",
            "maxItems": 64,
            "items": { "$ref": "client-tool-common.schema.json#/$defs/resourceAmount" }
          },
          "inventoryUsed": {
            "type": "array",
            "maxItems": 64,
            "items": { "$ref": "client-tool-common.schema.json#/$defs/resourceAmount" }
          },
          "unresolved": {
            "type": "array",
            "maxItems": 64,
            "items": { "$ref": "client-tool-common.schema.json#/$defs/resourceAmount" }
          },
          "workstations": {
            "type": "array",
            "maxItems": 32,
            "uniqueItems": true,
            "items": { "$ref": "../resource-ref.schema.json#/$defs/namespacedId" }
          },
          "issues": {
            "type": "array",
            "maxItems": 16,
            "uniqueItems": true,
            "items": {
              "enum": [
                "target_unknown",
                "cycle",
                "node_budget",
                "depth_budget",
                "time_budget",
                "process_unusable"
              ]
            }
          }
        }
      }
    },
    "unresolved": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "client-tool-common.schema.json#/$defs/resourceAmount"
      }
    },
    "cycles": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 16,
        "items": { "$ref": "../resource-ref.schema.json#/$defs/namespacedId" }
      }
    },
    "exploredNodes": { "type": "integer", "minimum": 0, "maximum": 2000 },
    "inventoryApplied": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "client-tool-common.schema.json#/$defs/warning" }
    }
  }
}

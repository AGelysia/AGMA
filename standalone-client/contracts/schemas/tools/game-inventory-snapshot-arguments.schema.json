{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/tools/game-inventory-snapshot-arguments.schema.json",
  "title": "AGMA Client Inventory Snapshot Arguments",
  "type": "object",
  "additionalProperties": false,
  "required": ["authorizationId", "generationId", "resourceIds"],
  "properties": {
    "authorizationId": { "type": "string", "format": "uuid" },
    "generationId": {
      "$ref": "client-tool-common.schema.json#/$defs/generationId"
    },
    "resourceIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "$ref": "../resource-ref.schema.json#/$defs/namespacedId" }
    }
  }
}

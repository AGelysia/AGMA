{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minecraft-agent.dev/schemas/1.0/tools/game-process-plan-arguments.schema.json",
  "title": "AGMA Client Process Plan Arguments",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceId",
    "amount",
    "generationId",
    "maxDepth",
    "maxNodes",
    "topK"
  ],
  "properties": {
    "resourceId": { "$ref": "../resource-ref.schema.json#/$defs/namespacedId" },
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1000000000
    },
    "generationId": {
      "$ref": "client-tool-common.schema.json#/$defs/generationId"
    },
    "maxDepth": { "type": "integer", "minimum": 1, "maximum": 12 },
    "maxNodes": { "type": "integer", "minimum": 1, "maximum": 2000 },
    "topK": { "type": "integer", "minimum": 1, "maximum": 3 }
  }
}
